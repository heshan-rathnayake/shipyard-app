# ── NextAuth ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET=

# ── OAuth Providers ───────────────────────────────────────────────────────────
# Fill these in from your Google Cloud Console / GitHub OAuth Apps
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://username:password@localhost:5432/database_name"

# ── Email (dev: MailHog) ───────────────────────────────────────────────────────
EMAIL_FROM="Shipyard <noreply@shipyard.dev>"
EMAIL_HOST="localhost"
EMAIL_PORT="1025"

# ── Email (prod: Resend) — leave blank in dev ──────────────────────────────────
RESEND_API_KEY=""

# ── Socket.IO ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SOCKET_URL="http://localhost:4000"
SOCKET_SECRET=

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRO_PRICE_ID=
CRON_SECRET=

