{
  "extends": "@shipyard/typescript-config/nextjs.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "strictNullChecks": true,
    "paths": {
      "@/*": ["./*"],
      "@/trpc/*": ["./src/trpc/*"],
      "@shipyard/ui": ["../../packages/ui/src"],
      "@shipyard/ui/*": ["../../packages/ui/src/*"],
      "@shipyard/api": ["../../packages/api/src"],
      "@shipyard/email": ["../../packages/email"],
      
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    "next.config.js",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
